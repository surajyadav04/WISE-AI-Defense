{
  "manifest_version": 3,
  "name": "WISE - Web Intelligence Security Engine",
  "version": "5.0",
  "description": "Real-time AI cybersecurity protection for browsers.",
  "permissions": [
    "webNavigation", 
    "storage",
    "activeTab",
    "scripting",
    "downloads",
    "notifications",
    "alarms"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js", "hover_script.js", "content_scanner.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup_build/index.html",
    "default_icon": "icons/icon.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["blocked.html", "telemetry_injector.js"],
      "matches": ["<all_urls>"]
    }
  ]
}